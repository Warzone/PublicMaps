<map proto="1.5.0">
<name>Levels</name>
<version>1.0.7</version>
<objective>Capture the enemy wools and place it at your victory monument!</objective>
<gamemode>ctw</gamemode>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="c14862ba-058a-44a2-a1c3-bfb0b462e198"/> <!-- roro28gutier -->
    <author uuid="ed1fe2bd-0431-4a56-8c5c-d4657389dd1f"/> <!-- artur1197 -->
    <author uuid="5df77c0e-1bc5-4fff-b41b-6763f29d4125"/> <!-- G_Marturet -->
    <author uuid="8eb34538-a6e0-4bc0-b695-b993f3f14aaa"/> <!-- Puyi2912 -->
</authors>
<teams>
    <team id="red-team" color="dark red" max="16">Red</team>
    <team id="blue-team" color="blue" max="16">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" amount="64" material="arrow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" material="iron axe"/>
        <item slot="4" amount="64" damage="1" material="wood"/>
        <item slot="31" amount="64" damage="1" material="wood"/>
        <item slot="5" amount="32" material="leaves"/>
        <item slot="8" material="golden apple"/>
        <helmet team-color="true" unbreakable="true" material="leather helmet"/>
        <chestplate team-color="true" unbreakable="true" material="leather chestplate"/>
    </kit>
    <kit id="portals">
        <effect duration="3" amplifier="3">heal</effect>
    </kit>
</kits>
<spawns>
    <spawn team="red-team" yaw="90" kit="spawn-kit">
        <region>
            <point>12.5,18,-35.5</point>
        </region>
    </spawn>
    <spawn team="blue-team" yaw="-90" kit="spawn-kit">
        <region>
            <point>-87.5,18,-35.5</point>
        </region>
    </spawn>
    <default>
        <region>
            <cuboid min="-39,51,45" max="-40,52,44"/>
        </region>
    </default>
</spawns>
<filters>
    <material id="only-iron">iron block</material>
    <deny id="deny-chest">
        <material>chest</material>
    </deny>
</filters>
<regions>
    <union id="iron-area">
        <rectangle id="blue-iron" min="-57,36" max="-83,15"/>
        <rectangle id="red-iron" min="8,36" max="-18,15"/>
    </union>
    <negative id="void-area">
        <union id="buildable-area">
            <rectangle id="middle" min="-25,14" max="-50,-8"/>
            <rectangle id="blue-iron-bridge" min="-73,11" max="-64,19"/>
            <rectangle id="red-iron-bridge" min="-2,11" max="-11,19"/>
        </union>
    </negative>
    <union id="spawns">
        <circle id="blue-spawn" center="-83.5,-35.5" radius="12"/>
        <circle id="red-spawn" center="8.5,-35.5" radius="12"/>
    </union>
    <union id="portal-areas">
        <cuboid id="red-above-portal" min="5,17,-31" max="4,19,-33"/>
        <cuboid id="red-below-portal" min="5,17,-38" max="4,19,-40"/>
        <cuboid id="blue-above-portal" min="-80,17,-40" max="-79,19,-38"/>
        <cuboid id="blue-below-portal" min="-80,17,-33" max="-79,19,-31"/>
    </union>
    <union id="victory-monuments">
        <cylinder id="red-victory-monument" base="18.5,12,-0.5" height="2" radius="1.5"/>
        <cylinder id="blue-victory-monument" base="-93.5,12,-0.5" height="2" radius="1.5"/>
    </union>
    <block id="red-above-block">15.5,24,-0.5</block>
    <block id="red-below-block">15.5,11,-0.5</block>
    <block id="blue-above-block">-90.5,24,-0.5</block>
    <block id="blue-below-block">-90.5,11,-0.5</block>
    <union id="wool-rooms">
        <circle id="blue-wool-rooms" center="-133.5,-0.5" radius="8"/> <!-- Red must enter -->
        <circle id="red-wool-rooms" center="58.5,-0.5" radius="8"/> <!-- Blue must enter -->
    </union>
    <union id="portal-protection">
        <rectangle id="red-portals" min="14,-2" max="17,1"/>
        <rectangle id="blue-portals" min="-89,1" max="-92,-2"/>
        <block>-90.5,24,-4.5</block>
        <block>-90.5,10,-4.5</block>
        <block>15.5,24,-4.5</block>
        <block>15.5,10,-4.5</block>
        <block>-90.5,23,-4.5</block>
        <block>-90.5,9,-4.5</block>
        <block>15.5,23,-4.5</block>
        <block>15.5,9,-4.5</block>
    </union>
    <!-- Applied -->
    <apply region="portal-areas" kit="portals"/>
    <apply region="portal-protection" block="never" message="You may not edit the portal area!"/>
    <apply region="wool-rooms" block="deny-chest"/>
    <apply region="red-wool-rooms" block="blue-team" use="blue-team" message="You may not modify your own wool room!"/>
    <apply region="red-wool-rooms" enter="blue-team" message="You may not enter your own wool room!"/>
    <apply region="blue-wool-rooms" block="red-team" use="red-team" message="You may not modify your own wool room!"/>
    <apply region="blue-wool-rooms" enter="red-team" message="You may not enter your own wool room!"/>
    <apply region="spawns" block="never" message="You may not modify the spawn area!"/>
    <apply enter="never" region="victory-monuments" message="You may not obstruct the victory monuments!"/>
    <apply block="deny(void)" region="void-area" message="You may not edit the void area!"/>
</regions>
<portals>
    <portal x="@-90.5" y="@24" z="@-4.5" pitch="@10" yaw="@-90" filter="blue-team">
        <region>
            <region id="blue-above-portal"/>
            <region id="blue-below-block"/>
        </region>
    </portal>
    <portal x="@-90.5" y="@10" z="@-4.5" pitch="@10" yaw="@-90" filter="blue-team">
        <region>
            <region id="blue-below-portal"/>
            <region id="blue-above-block"/>
        </region>
    </portal>
    <portal x="@15.5" y="@24" z="@-4.5" pitch="@10" yaw="@90" filter="red-team">
        <region>
            <region id="red-above-portal"/>
            <region id="red-below-block"/>
        </region>
    </portal>
    <portal x="@15.5" y="@10" z="@-4.5" pitch="@10" yaw="@90" filter="red-team">
        <region>
            <region id="red-below-portal"/>
            <region id="red-above-block"/>
        </region>
    </portal>
</portals>
<wools>
    <wool team="blue-team" color="lime" location="58.5,25,-0.5">
        <monument>
            <block>-94,13,-1</block>
        </monument>
    </wool>
    <wool team="blue-team" color="cyan" location="58.5,7,-0.5">
        <monument>
            <block>-94,12,-1</block>
        </monument>
    </wool>
    <wool team="red-team" color="yellow" location="-133.5,25,-0.5">
        <monument>
            <block>18,13,-1</block>
        </monument>
    </wool>
    <wool team="red-team" color="orange" location="-133.5,7,-0.5">
        <monument>
            <block>18,12,-1</block>
        </monument>
    </wool>
</wools>
<renewables>
    <renewable region="iron-area" renew-filter="only-iron"/>
</renewables>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>string</item>
    <item>sapling</item>
    <item>apple</item>
</itemremove>
<itemkeep>
    <item>arrow</item>
    <item>wood</item>
    <item>leaves</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" damage="1" material="wood"/>
        <item amount="8" material="leaves"/>
        <item amount="16" material="arrow"/>
    </kill-reward>
</kill-rewards>
<hunger>
    <depletion>off</depletion>
</hunger>
<timelock>on</timelock>
<maxbuildheight>40</maxbuildheight>
</map>
