<map proto="1.5.0" min-server-version="1.21.11">
<name>Icarus Fortress</name>
<version>1.0.0</version>
<created>2026-03-19</created>
<objective>Destroy the enemy team's monument!</objective>
<gamemode>dtm</gamemode>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="f610e558-a3c8-44fb-8622-68cc49dbc18f"/> <!-- jcane -->
</authors>
<contributors>
    <contributor uuid="63ddf58a-ba2c-4d39-8481-6358bb46c63a" contribution="xml"/> <!-- samschaap -->
</contributors>
<teams>
    <team id="red-team" color="red" max="14">Red</team>
    <team id="blue-team" color="blue" max="14">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" unbreakable="true" material="crossbow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe" enchantment="efficiency"/>
        <item slot="3" unbreakable="true" material="wooden axe" enchantment="efficiency:2"/>
        <item slot="4" unbreakable="true" material="iron spade"/>
        <item slot="5" amount="64" material="stripped spruce log"/>
        <item slot="32" amount="32" material="arrow"/>
        <item slot="6" amount="32" material="leaves"/>
        <item slot="33" unbreakable="true" material="shears"/>
        <item slot="8" material="golden apple"/>
        <item slot="9" material="elytra"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true"  material="chainmail chestplate" enchantment="projectile_protection:2"/>
        <leggings unbreakable="true" team-color="true" material="leather leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="5s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default yaw="0">
        <region>
            <point>-30.5,70,-38.5</point>
        </region>
    </default>
    <spawn team="red-team" kit="spawn-kit" yaw="135">
        <regions>
            <point>70.5,57,-29.5</point>
        </regions>
    </spawn>
    <spawn team="blue-team" kit="spawn-kit" yaw="-45">
        <regions>
            <point>-131.5,57,58.5</point>
        </regions>
    </spawn>
</spawns>
<filters>
    <deny id="deny-beacon">
        <material>beacon</material>
    </deny>
</filters>
<regions>
    <negative id="void-area">
        <rectangle id="buildable-area" min="-7,-37" max="-54,66"/>
    </negative>
    <union id="spawns">
        <cuboid id="red-spawn" min="76,90,-40" max="42,45,-13"/>
        <cuboid id="blue-spawn" min="-137,90,69" max="-103,45,42"/>
    </union>
    <below y="0" id="below-map"/>
    <apply use="deny-beacon"/>
    <apply block="never" region="below-map"/>
    <apply block="never" region="spawns" message="You may not modify the spawn area!"/>
    <apply enter="red-team" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="blue-team" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply block="deny(void)" region="void-area" message="You may not modify the void!"/>
</regions>
<destroyables name="Monument" material="emerald block" mode-changes="true" show-progress="true">
    <destroyable owner="red-team">
        <region>
            <cuboid min="52,31,46" max="57,38,51"/>
        </region>
    </destroyable>
    <destroyable owner="blue-team">
        <region>
            <cuboid min="-113,31,-17" max="-118,38,-22"/>
        </region>
    </destroyable>
</destroyables>
<modes>
    <mode id="gold-mode" after="20m" name="`6GOLD MONUMENT MODE" material="gold block"/>
</modes>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>crossbow</tool>
    <tool>iron pickaxe</tool>
    <tool>wooden axe</tool>
    <tool>iron spade</tool>
    <tool>elytra</tool>
    <tool>shears</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>chainmail chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>sapling</item>
    <item>seeds</item>
    <item>snow ball</item>
    <item>emerald block</item>
    <item>gold block</item>
</itemremove>
<itemkeep>
    <item>stripped spruce log</item>
    <item>leaves</item>
    <item>arrow</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" material="stripped spruce log"/>
        <item amount="16" material="leaves"/>
        <item amount="8" material="arrow"/>
    </kill-reward>
</kill-rewards>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>60</maxbuildheight>
</map>
