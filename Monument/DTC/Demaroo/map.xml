<map proto="1.5.0">
<name>Demaroo</name>
<version>1.2.0</version>
<created>2014-06-15</created>
<objective>Leak lava from the enemy's obsidian core!</objective>
<gamemode>dtc</gamemode>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="e3fdaea1-8a19-4378-8ad7-41cf63f5d141"/> <!-- Avaleer -->
</authors>
<contributors>
    <contributor uuid="8fda3d23-991f-457c-b679-45ed4b0a576d" contribution="XML"/> <!-- feidi_22 -->
</contributors>
<teams>
    <team id="blue" color="blue" max="12">Blue</team>
    <team id="orange" color="gold" max="12">Orange</team>
</teams>
<spawns>
    <spawn team="blue" kit="spawn-kit" region="blue-spawn" yaw="0"/>
    <spawn team="orange" kit="spawn-kit" region="orange-spawn" yaw="180"/>
    <default region="obs-spawn" yaw="-90"/>
</spawns>
<kits>
    <kit id="spawn-kit" force="true">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="diamond pickaxe" unbreakable="true"/>
        <item slot="3" material="iron axe" unbreakable="true">
            <enchantment level="2">efficiency</enchantment>
        </item>
        <item slot="4" material="wood" amount="64"/>
        <item slot="5" material="wood" amount="64"/>
        <item slot="6" material="stained glass" amount="32" team-color="true"/>
        <item slot="7" material="golden apple"/>
        <item slot="8" material="shears" name="`6TNT Defuser" lore="`7Right click to defuse teammate's TNT|`7Does not work in `9water`7!"/>
        <item slot="28" material="arrow" amount="64"/>
        <helmet material="leather helmet" unbreakable="true" team-color="true"/>
        <chestplate material="chainmail chestplate" unbreakable="true"/>
        <leggings material="leather leggings" unbreakable="true" team-color="true"/>
        <boots material="iron boots" unbreakable="true"/>
        <game-mode>adventure</game-mode>
        <effect amplifier="10">damage resistance</effect>
        <knockback-reduction>1</knockback-reduction>
    </kit>
    <kit id="leaving-spawn" force="true">
        <game-mode>survival</game-mode>
        <effect amplifier="10" duration="1s">damage resistance</effect>
        <knockback-reduction>0</knockback-reduction>
    </kit>
</kits>
<kill-rewards>
    <kill-reward>
        <item material="arrow" amount="16"/>
        <item material="wood" amount="16"/>
        <item material="stained glass" amount="8" team-color="true"/>
    </kill-reward>
</kill-rewards>
<regions>
    <cylinder id="obs-spawn" base="25,26,109" radius="2" height="0"/>
    <block id="blue-spawn" location="-20,21,53"/>
    <block id="orange-spawn" location="-20,21,167"/>
    <negative id="outside-spawn-drops">
        <union id="spawn-drops">
            <union id="orange-spawn-drops">
                <cuboid min="-38,19,164" max="-1,oo,169"/>
                <cuboid min="-23,19,163" max="-16,oo,170"/>
            </union>
            <union id="blue-spawn-drops">
                <cuboid min="-38,19,52" max="-1,oo,57"/>
                <cuboid min="-23,19,51" max="-16,oo,58"/>
            </union>
        </union>
    </negative>
    <cuboid id="blue-core" min="-18,10,84" max="-22,15,88"/>
    <cuboid id="orange-core" min="-18,10,132" max="-22,15,136"/>
    <complement id="playable-area">
        <rectangle min="-46,44" max="7,177"/>
        <region id="spawn-drops"/>
    </complement>
    <apply region="outside-spawn-drops" kit="leaving-spawn"/>
    <apply region="blue-spawn-drops" enter="blue" message="You may not enter the enemy spawn!"/>
    <apply region="orange-spawn-drops" enter="orange" message="You may not enter the enemy spawn!"/>
    <apply region="spawn-drops" block="never"/>
    <apply region="everywhere" block="playable-area"/>
</regions>
<maxbuildheight>19</maxbuildheight>
<cores material="obsidian" leak="5" mode-changes="true">
    <core team="orange" region="orange-core"/>
    <core team="blue" region="blue-core"/>
</cores>
<modes>
    <mode after="15m" material="gold block"/>
    <mode after="25m" material="glass"/>
</modes>
<item-mods>
    <rule>
        <match>
            <material>iron helmet</material>
            <material>iron chestplate</material>
            <material>iron leggings</material>
            <material>iron boots</material>
            <material>iron sword</material>
            <material>iron pickaxe</material>
            <material>iron axe</material>
            <material>iron spade</material>
            <material>diamond helmet</material>
            <material>diamond chestplate</material>
            <material>diamond leggings</material>
            <material>diamond boots</material>
            <material>diamond sword</material>
            <material>diamond pickaxe</material>
            <material>diamond axe</material>
            <material>diamond spade</material>
            <material>gold helmet</material>
            <material>gold chestplate</material>
            <material>gold leggings</material>
            <material>gold boots</material>
            <material>gold sword</material>
            <material>gold pickaxe</material>
            <material>gold axe</material>
            <material>gold spade</material>
        </match>
        <modify unbreakable="true"/>
    </rule>
</item-mods>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>diamond pickaxe</tool>
    <tool>iron axe</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>chainmail chestplate</item>
    <item>leather boots</item>
    <item>leather leggings</item>
    <item>obsidian</item>
    <item>gold block</item>
    <item>sapling</item>
</itemremove>
<itemkeep>
    <item>log</item>
    <item>wood</item>
    <item>stained glass</item>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
