<map proto="1.5.0">
<name>Pharaoh's Catacombs</name>
<gamemode>tdm</gamemode>
<version>1.4.10</version>
<objective>Get the most amount of kills for your team while buying new gear!</objective>
<authors>
    <author uuid="459fd919-0d58-401a-9601-6cab1eb721ab"/> <!-- Reshif -->
</authors>
<teams>
    <team id="blue-team" color="blue" max="14">Blue</team>
    <team id="red-team" color="dark red" max="14">Red</team>
</teams>
<kits>
    <kit id="obs">
        <effect>night vision</effect>
    </kit>
    <kit id="spawn-kit" parents="obs">
        <item slot="0" material="stone sword"/>
        <item slot="1" enchantment="arrow infinite" material="bow"/>
        <item slot="2" amount="64" material="cooked beef"/>
        <item slot="27" amount="64" material="apple"/>
        <item slot="28" material="arrow"/>
        <chestplate enchantment="protection fall:4;protection projectile:2" material="gold chestplate"/>
    </kit>
    <kit id="strength">
        <effect duration="4">increase damage</effect>
    </kit>
    <kit id="regen">
        <effect duration="2" amplifier="10">regeneration</effect>
    </kit>
</kits>
<spawns>
    <spawn team="blue-team" kit="spawn-kit" yaw="180">
        <region>
            <cylinder base="0,85,6" radius="2" height="0"/>
        </region>
    </spawn>
    <spawn team="red-team" kit="spawn-kit">
        <region>
            <cylinder base="0,85,-6" radius="2" height="0"/>
        </region>
    </spawn>
    <default kit="obs">
        <region>
            <cylinder base="1,60,1" radius="2" height="0"/>
        </region>
    </default>
</spawns>
<filters>
    <material id="only-tnt">tnt</material>
</filters>
<regions>
    <union id="no-build">
        <cuboid min="-13,84,-14" max="14,91,13"/> <!-- Shop area -->
        <union id="red-spawn">
            <cuboid min="8,63,-27" max="19,68,-10"/>
            <cuboid min="0,63,-27" max="7,68,-21"/>
            <cuboid min="18,63,-25" max="23,68,-20"/>
        </union>
        <cuboid id="blue-spawn" min="-13,63,23" max="19,68,32"/>
    </union>
    <union id="spawn-portals">
        <cuboid id="red-spawn-portal" min="-1,86,-13" max="2,89,-12"/>
        <cuboid id="blue-spawn-portal" min="-1,86,11" max="2,89,12"/>
    </union>
    <cuboid id="red-return-portal" min="10,64,-21" max="12,67,-18"/>
    <cuboid id="blue-return-portal" min="8,64,24" max="11,67,26"/>
    <apply kit="strength" region="spawn-portals"/>
    <apply kit="regen" enter="red-team" region="red-return-portal"/>
    <apply kit="regen" enter="blue-team" region="blue-return-portal"/>
    <apply enter="blue-team" message="You may not enter the enemy team's spawn!" region="blue-spawn"/>
    <apply enter="red-team" message="You may not enter the enemy team's spawn!" region="red-spawn"/>
    <apply block="never" message="You may not break or place blocks here!" region="no-build"/>
    <apply block-place="only-tnt" block-break="never"/>
</regions>
<time>8m</time>
<score>
    <kills>1</kills>
</score>
<portals>
    <portal x="@9.5" y="@64" z="@28" region="blue-spawn-portal"/>
    <portal x="@0.5" y="@85" z="@5.5" region="blue-return-portal"/>
    <portal x="@14" y="@64" z="@-19.5" yaw="90" region="red-spawn-portal"/>
    <portal x="@0.5" y="@85" z="@-6.5" yaw="-90" region="red-return-portal"/>
</portals>
<itemremove>
    <item>apple</item>
    <item>cooked beef</item>
    <item>gold chestplate</item>
    <item>glass bottle</item>
</itemremove>
<toolrepair>
    <tool>stone sword</tool>
    <tool>gold chestplate</tool>
    <tool>bow</tool>
</toolrepair>
<itemkeep>
    <item>gold ingot</item>
    <item>gold block</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="3" material="gold ingot"/>
    </kill-reward>
</kill-rewards>
<tnt>
    <instantignite>on</instantignite>
    <licensing>off</licensing>
    <friendly-defuse>off</friendly-defuse>
    <blockdamage>off</blockdamage>
</tnt>
<disabledamage>
    <damage ally="true" self="false" enemy="false" other="false">block explosion</damage>
</disabledamage>
<mobs>
    <filter>
        <spawn>spawner</spawn>
    </filter>
</mobs>
</map>
