<map proto="1.5.0">
<name>Brisked</name>
<version>1.2.0</version>
<objective>Collect the most points in 7 minutes!</objective>
<gamemode>koth</gamemode>
<gamemode>scorebox</gamemode>
<created>2015-03-14</created>
<authors>
    <author uuid="f690a591-348b-482e-a18d-7779d0c0a28c"/> <!-- mitchiii -->
</authors>
<broadcasts>
    <alert after="480s">`aHills now award double points!</alert>
    <tip after="15s" every="2m">`rCollect `etokens `rfrom the `ecentral island `rand return them to your `eteam scorebox `rfor bonus points!</tip>
    <tip after="45s" every="2m">`rControlling hills rewards you with `emore valuable `rtokens!</tip>
</broadcasts>
<teams>
    <team id="purple" color="dark purple" max="14">Purple</team>
    <team id="orange" color="gold" max="14">Orange</team>
</teams>
<spawns>
    <spawns team="purple" kit="main">
        <spawn region="purple-spawn" yaw="-90"/>
        <spawn region="purple-spawn" yaw="180"/>
    </spawns>
    <spawns team="orange" kit="main">
        <spawn region="orange-spawn" yaw="90"/>
        <spawn region="orange-spawn" yaw="0"/>
    </spawns>
    <default region="observer-spawn" yaw="-45"/>
</spawns>
<kits>
    <kit id="main">
        <clear/>
        <item slot="0" material="stone sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="leaves" damage="1" amount="48"/>
        <item slot="7" material="arrow" amount="32"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" material="chainmail leggings">
            <enchantment level="2">projectile protection</enchantment>
        </leggings>
        <boots unbreakable="true" material="iron boots"/>
        <effect duration="8s" amplifier="10">heal</effect>
        <effect duration="8s" amplifier="10">damage resistance</effect>
    </kit>
</kits>
<kill-rewards>
    <kill-reward>
        <item material="arrow" amount="12"/>
        <item material="leaves" damage="1" amount="12"/>
    </kill-reward>
    <kill-reward filter="reward-streak">
        <item material="tnt" amount="2"/>
    </kill-reward>
</kill-rewards>
<filters>
    <all id="allowed-blocks">
        <any>
            <material>leaves</material>
            <material>tnt</material>
        </any>
        <not>
            <void/>
        </not>
    </all>
    <all id="owns-all-points">
        <captured>hill-nw</captured>
        <captured>hill-se</captured>
    </all>
    <any id="owns-any-point">
        <captured id="owns-nw-point">hill-nw</captured>
        <captured id="owns-se-point">hill-se</captured>
    </any>
    <any id="none-or-owns-nw-point">
        <filter id="owns-nw-point"/>
        <not>
            <any>
                <captured team="orange">hill-nw</captured>
                <captured team="purple">hill-nw</captured>
            </any>
        </not>
    </any>
    <any id="none-or-owns-se-point">
        <filter id="owns-se-point"/>
        <not>
            <any>
                <captured team="orange">hill-se</captured>
                <captured team="purple">hill-se</captured>
            </any>
        </not>
    </any>
    <carrying id="carrying-token-potential">
        <item material="double plant"/>
    </carrying>
    <kill-streak id="reward-streak" count="3" repeat="true"/>
</filters>
<regions>
    <cylinder id="observer-spawn" base="-27.5,74.5,-106.5" radius="3" height="1"/>
    <point id="purple-spawn">-66.5,48.5,-47.5</point>
    <point id="orange-spawn">31.5,48.5,-145.5</point>
    <union id="team-depots">
        <cuboid id="orange-depot" min="33,40,-148" max="29,42,-144"/>
        <cuboid id="purple-depot" min="-69,40,-46" max="-65,42,-50"/>
    </union>
    <cylinder id="hill-nw-capture" base="-33.5,29,-112.5" radius="5" height="3"/>
    <cylinder id="hill-se-capture" base="-1.5,29,-80.5" radius="5" height="3"/>
    <cylinder id="hill-nw-progress" base="-33.5,21,-112.5" radius="7" height="15"/>
    <cylinder id="hill-se-progress" base="-1.5,21,-80.5" radius="7" height="15"/>
    <cuboid id="nw-jump-complete" min="-40,20,-119" max="-65,38,-144"/>
    <cuboid id="se-jump-complete" min="4,20,-75" max="29,38,-50"/>
    <cylinder id="wool-island-complete" base="-17.5,19,-96.5" radius="4" height="19"/>
    <cylinder id="nw-pad" base="-55.5,31,-134.5" radius="1.2" height="1"/>
    <cylinder id="ne-pad" base="9.5,29,-123.5" radius="1.2" height="1"/>
    <cylinder id="se-pad" base="-44.5,29,-69.5" radius="1.2" height="1"/>
    <cylinder id="sw-pad" base="20.5,31,-58.5" radius="1.2" height="1"/>
    <cylinder id="mid-pad" base="-17.5,26,-96.5"  radius="1" height="1"/>
    <point id="spawner-n">-17.5,42,-99.5</point>
    <point id="spawner-e">-14.5,42,-96.5</point>
    <point id="spawner-s">-17.5,42,-93.5</point>
    <point id="spawner-w">-20.5,42,-96.5</point>
    <apply region="ne-pad" velocity="@-0.7,2.3,0.7"/>
    <apply region="se-pad" velocity="@0.7,2.3,-0.7"/>
    <apply region="nw-pad" velocity="@2,2.3,2" filter="none-or-owns-nw-point"/>
    <apply region="sw-pad" velocity="@-2,2.3,-2" filter="none-or-owns-se-point"/>
    <apply region="mid-pad" velocity="@0,2.5,0"/>
    <apply block="allowed-blocks" message="You may not interact with this material!"/>
</regions>
<falling-blocks>
    <rule>
        <filter>
            <material>leaves</material>
        </filter>
        <sticky>
            <any>
                <material>log 2</material>
                <material>smooth brick</material>
                <material>leaves</material>
                <material>stained clay</material>
                <material>stained glass</material>
            </any>
        </sticky>
    </rule>
</falling-blocks>
<time>7m</time>
<control-points capture-time="12s" decay="0" points="1" points-growth="300" capture-rule="lead" show-progress="true" required="false">
    <control-point id="hill-nw" name="North West Hill" capture="hill-nw-capture" progress="hill-nw-progress" captured="nw-jump-complete"/>
    <control-point id="hill-se" name="South East Hill" capture="hill-se-capture" progress="hill-se-progress" captured="se-jump-complete"/>
</control-points>
<score>
    <box region="purple-depot" filter="purple">
        <redeemables>
            <item points="1">clay brick</item>
            <item points="4">iron ingot</item>
            <item points="8">gold ingot</item>
        </redeemables>
    </box>
    <box region="orange-depot" filter="orange">
        <redeemables>
            <item points="1">clay brick</item>
            <item points="4">iron ingot</item>
            <item points="8">gold ingot</item>
        </redeemables>
    </box>
</score>
<portals>
    <portal region="team-depots" destination="purple-spawn" filter="purple" yaw="@-90" pitch="@0"/>
    <portal region="team-depots" destination="orange-spawn" filter="orange" yaw="@90"  pitch="@0"/>
</portals>
<spawners player-region="everywhere" max-entities="1" delay="3s">
    <spawner spawn-region="spawner-n">
        <item material="double plant"/>
    </spawner>
    <spawner spawn-region="spawner-e">
        <item material="double plant"/>
    </spawner>
    <spawner spawn-region="spawner-s">
        <item material="double plant"/>
    </spawner>
    <spawner spawn-region="spawner-w">
        <item material="double plant"/>
    </spawner>
</spawners>
<actions>
    <trigger scope="player" filter="carrying-token-potential">
        <action>
            <take-payment>
                <payment currency="double plant" price="1"/>
                <success-action>
                    <action filter="owns-all-points">
                        <kit deduct-items="false">
                            <item material="gold ingot" name="`rGold Token `8(`68 points`8)"/>
                        </kit>
                    </action>
                    <action filter="all(owns-any-point, not(owns-all-points))">
                        <kit deduct-items="false">
                            <item material="iron ingot" name="`rSilver Token `8(`b4 points`8)"/>
                        </kit>
                    </action>
                    <action filter="not(owns-any-point)">
                        <kit deduct-items="false">
                            <item material="clay brick" name="`rBronze Token `8(`71 point`8)"/>
                        </kit>
                    </action>
                </success-action>
            </take-payment>
        </action>
    </trigger>
</actions>
<itemremove>
    <item>stone sword</item>
    <item>bow</item>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>iron boots</item>
    <item>sapling</item>
    <item>apple</item>
    <item>sign</item>
</itemremove>
<itemkeep>
    <item>arrow</item>
    <item>golden apple</item>
    <item>tnt</item>
    <item>leaves</item>
    <item>clay brick</item>
    <item>iron ingot</item>
    <item>gold ingot</item>
</itemkeep>
<disabledamage>
    <damage>fall</damage>
    <damage ally="true" self="false" enemy="false" other="false">block explosion</damage>
</disabledamage>
<tnt>
    <instantignite>on</instantignite>
    <friendly-defuse>off</friendly-defuse>
    <licensing>off</licensing>
    <fuse>3s</fuse>
</tnt>
<maxbuildheight>50</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
